---
const title = "Canonical Folder - Test Page";
const description = "This is a test page to verify the canonical folder is working correctly.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body style="font-family: sans-serif; max-width: 800px; margin: 40px auto; padding: 0 20px;">

    <h1>✅ Canonical Folder is Working!</h1>
    <p style="color: gray;">This test page confirms the <strong>canonical</strong> folder was created successfully.</p>

    <hr />

    <h2>📁 Folder Details</h2>
    <table style="width: 100%; border-collapse: collapse;">
      <tr style="border-bottom: 1px solid #eee;">
        <td style="padding: 8px; color: gray;">Folder</td>
        <td style="padding: 8px;"><code>src/pages/blog/canonical/</code></td>
      </tr>
      <tr style="border-bottom: 1px solid #eee;">
        <td style="padding: 8px; color: gray;">Live URL</td>
        <td style="padding: 8px;"><code>tobecurious.win/blog/canonical/test-page</code></td>
      </tr>
      <tr style="border-bottom: 1px solid #eee;">
        <td style="padding: 8px; color: gray;">Purpose</td>
        <td style="padding: 8px;">Canonical tag test pages</td>
      </tr>
      <tr>
        <td style="padding: 8px; color: gray;">Status</td>
        <td style="padding: 8px; color: green;"><strong>✅ Active</strong></td>
      </tr>
    </table>

    <hr />

    <p style="color: gray; font-size: 14px;">
      You can delete this test page once you confirm it's working. 
      Replace it with real canonical test pages!
    </p>

    <a href="/blog" style="color: #333;">← Back to Blog</a>

  </body>
</html>
